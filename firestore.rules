rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper visibility checks
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
       return isSignedIn() && request.auth.uid == userId;
    }

    // --- USERS & PROFILES ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
    }

    // --- KITTENS (Ads) ---
    match /kittens/{kittenId} {
      allow read: if true; // Public listings
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid));
      allow delete: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    // --- BIRTH DECLARATIONS ---
    match /birth_declarations/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // --- MATING CERTIFICATES (Saillies) ---
    match /mating_certificates/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- PEDIGREE REQUESTS ---
    match /pedigree_requests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- TRANSFERS ---
    match /transfers/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- AFFIXE REQUESTS ---
    match /affixe_requests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- MEMBERSHIPS (Adhésions) ---
    match /memberships/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow create: if true; // Anyone can apply
      allow update, delete: if isAdmin();
    }

    // --- MESSAGES (Chat) ---
    match /messages/{messageId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
